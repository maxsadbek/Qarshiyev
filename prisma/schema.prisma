generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// SYSTEM & CONFIGURATION
// ==========================================

model Region {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String     @unique @db.VarChar(50)
  name      String     @db.VarChar(100)
  districts District[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("regions")
}

model District {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  regionId  String    @db.Uuid
  name      String    @db.VarChar(100)
  region    Region    @relation(fields: [regionId], references: [id], onDelete: Restrict)
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([regionId])
  @@map("districts")
}

model Language {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(10) // e.g. 'uz', 'ru', 'en'
  name      String   @db.VarChar(50)
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("languages")
}

// ==========================================
// USERS & PROFILES
// ==========================================

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  name         String    @db.VarChar(200)
  phone        String?   @db.VarChar(20)
  telegramId   String?   @unique @db.VarChar(50)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?

  student       Student?
  teacher       Teacher?
  admin         Admin?
  activityLogs  ActivityLog[]
  auditLogs     AuditLog[]
  sessions      Session[]
  accountLock   AccountLock?
  resetTokens   PasswordResetToken[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([telegramId])
  @@index([isActive])
  @@index([lastLogin])
  @@map("users")
}

model Admin {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @unique @db.Uuid
  department String?  @db.VarChar(100)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("admins")
}

model Teacher {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @unique @db.Uuid
  bio             String?  @db.Text
  experienceYears Int      @default(0)
  specialization  String?  @db.VarChar(100)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses         Course[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("teachers")
}

model Student {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String        @unique @db.Uuid
  districtId   String?       @db.Uuid
  dateOfBirth  DateTime?     @db.Date
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  district     District?     @relation(fields: [districtId], references: [id], onDelete: SetNull)
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([districtId])
  @@map("students")
}

// ==========================================
// BUSINESS DOMAIN (COURSES & APPLICATIONS)
// ==========================================

model Course {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String  @db.VarChar(255)
  description String  @db.Text
  price       Decimal @db.Decimal(10, 2)
  teacherId   String  @db.Uuid
  languageId  String  @db.Uuid
  isActive    Boolean @default(true)

  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  language     Language      @relation(fields: [languageId], references: [id], onDelete: Restrict)
  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([languageId])
  @@map("courses")
}

model Application {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String            @db.Uuid
  courseId  String            @db.Uuid
  status    ApplicationStatus @default(PENDING)
  notes     String?           @db.Text

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ==========================================
// SYSTEM LOGS & NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  title     String   @db.VarChar(255)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model ActivityLog {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String? @db.Uuid
  action    String  @db.VarChar(100) // e.g. 'LOGIN_SUCCESS', 'COURSE_CREATED'
  entity    String? @db.VarChar(100) // e.g. 'Course', 'Application'
  entityId  String? @db.VarChar(100)
  ipAddress String? @db.VarChar(45)
  userAgent String? @db.VarChar(512)
  details   Json?

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ==========================================
// SECURITY: AUDIT TRAIL
// ==========================================

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @db.Uuid
  action    String   @db.VarChar(100) // e.g. 'STATUS_CHANGED'
  entity    String   @db.VarChar(100) // e.g. 'User', 'Application', 'Course'
  entityId  String?  @db.VarChar(100)
  field     String?  @db.VarChar(100)
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.VarChar(512)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==========================================
// SECURITY: SESSIONS
// ==========================================

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique @db.VarChar(255)
  userId    String   @db.Uuid
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ==========================================
// SECURITY: ACCOUNT LOCKOUT
// ==========================================

model AccountLock {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @db.Uuid
  failedAttempts  Int      @default(0)
  lockedUntil     DateTime?
  lastFailureAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([lockedUntil])
  @@map("account_locks")
}

// ==========================================
// SECURITY: PASSWORD RESET TOKENS
// ==========================================

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}


// ==========================================
// NOTIFICATION SYSTEM
// ==========================================

model NotificationLog {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event      NotificationEvent
  channel    NotificationChannel
  recipient  String             @db.VarChar(255)
  subject    String?            @db.VarChar(500)
  body       String             @db.Text
  status     DispatchStatus     @default(PENDING)
  attempts   Int                @default(0)
  error      String?            @db.Text
  sentAt     DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([event])
  @@index([channel])
  @@index([status])
  @@index([recipient])
  @@map("notification_logs")
}

enum NotificationEvent {
  REGISTRATION
  ACCEPTANCE
  REJECTION
  PENDING_STATUS
  REMINDER
  CUSTOM
}

enum NotificationChannel {
  TELEGRAM
  EMAIL
  DASHBOARD
}

enum DispatchStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

// ==========================================
// MARKETPLACE / GAMING BOT
// ==========================================

model MarketplaceUser {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telegramId    String            @unique @db.VarChar(50)
  username      String?           @db.VarChar(100)
  firstName     String?           @db.VarChar(100)
  lastName      String?           @db.VarChar(100)
  language      String            @default("en") @db.VarChar(10)
  balance       Decimal           @default(0) @db.Decimal(12, 2)
  referralCode  String            @unique @db.VarChar(20)
  referredBy    String?           @db.Uuid
  isBlocked     Boolean           @default(false)
  registeredAt  DateTime          @default(now())
  lastActivity  DateTime          @default(now())

  orders        MarketplaceOrder[]
  reviews       MarketplaceReview[]
  referrals     MarketplaceUser    @relation("Referrals", fields: [referredBy], references: [id], onDelete: SetNull)
  referredUsers MarketplaceUser[]  @relation("Referrals")
  transactions  WalletTransaction[]

  @@index([telegramId])
  @@index([referralCode])
  @@index([registeredAt])
  @@map("marketplace_users")
}

model MarketplaceOrder {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String              @db.Uuid
  serviceKey    String              @db.VarChar(50)
  game          String              @db.VarChar(100)
  quantity      Int                 @default(1)
  username      String              @db.VarChar(100)
  platform      String              @db.VarChar(50)
  notes         String?             @db.Text
  promoCode     String?             @db.VarChar(50)
  totalPrice    Decimal             @default(0) @db.Decimal(12, 2)
  status        MarketplaceOrderStatus @default(PENDING)
  adminNote     String?             @db.Text
  paymentMethod String?             @db.VarChar(50)
  paymentProof  String?             @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          MarketplaceUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews       MarketplaceReview[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("marketplace_orders")
}

enum MarketplaceOrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

model MarketplaceReview {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  orderId   String   @db.Uuid
  rating    Int      @db.SmallInt
  text      String   @db.Text
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())

  user      MarketplaceUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([isApproved])
  @@map("marketplace_reviews")
}

model MarketplacePromoCode {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(50)
  discountPct Int      @default(0)
  maxUses     Int      @default(100)
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([code])
  @@map("marketplace_promo_codes")
}

model WalletTransaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  type      String   @db.VarChar(20) // DEPOSIT, WITHDRAW, REFERRAL_BONUS, ORDER_PAYMENT
  reference String?  @db.VarChar(100)
  status    String   @default("COMPLETED") @db.VarChar(20)
  createdAt DateTime @default(now())

  user      MarketplaceUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("wallet_transactions")
}