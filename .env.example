# ============================================================
# Qarshiyev AVYD — Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in your actual values.
# DO NOT commit .env.local to version control.

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# DATABASE (Prisma / PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/qarshiyev_db?schema=public"

# ============================================================
# AUTHENTICATION
# ============================================================
NEXT_PUBLIC_AUTH_COOKIE_NAME=qarshiyev_session
AUTH_SECRET=your-auth-secret-key-min-32-chars

# ============================================================
# TELEGRAM BOT
# ============================================================
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# ============================================================
# EMAIL (Resend)
# ============================================================
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@qarshiyev.uz
EMAIL_REPLY_TO=support@qarshiyev.uz

# ============================================================
# AI / LLM
# ============================================================
OPENROUTER_API_KEY=your-openrouter-api-key
OPENAI_API_KEY=your-openai-api-key

# ============================================================
# FILE STORAGE
# ============================================================
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=public-assets
UPLOADTHING_SECRET=your-uploadthing-secret
UPLOADTHING_APP_ID=your-uploadthing-app-id

# ============================================================
# MONITORING & LOGGING
# ============================================================
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

# ============================================================
# PAYMENT (Future)
# ============================================================
PAYME_MERCHANT_ID=your-merchant-id
PAYME_SECRET_KEY=your-payme-secret
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret
