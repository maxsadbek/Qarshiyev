# ── Qarshiyev AI Assistant — LLM Fallback configuration ──
# All fields are OPTIONAL. If no API key is provided, the assistant
# answers entirely from the local knowledge base and uses a safe
# fallback message for unknown questions (no calls to external APIs).

# Your OpenAI-compatible API key
VITE_OPENAI_API_KEY=

# Any OpenAI-compatible endpoint (OpenAI, Azure, OpenRouter, Together, etc.)
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# Model name
VITE_OPENAI_MODEL=gpt-4o-mini
